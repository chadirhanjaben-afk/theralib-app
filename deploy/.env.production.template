# ============================================================
# Theralib - Production Environment Variables
# Copie ce fichier en .env.production et remplis les valeurs
# ============================================================

# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=__COPIER_DEPUIS_ENV_LOCAL__
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=__COPIER_DEPUIS_ENV_LOCAL__
NEXT_PUBLIC_FIREBASE_PROJECT_ID=__COPIER_DEPUIS_ENV_LOCAL__
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=__COPIER_DEPUIS_ENV_LOCAL__
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=__COPIER_DEPUIS_ENV_LOCAL__
NEXT_PUBLIC_FIREBASE_APP_ID=__COPIER_DEPUIS_ENV_LOCAL__

# Stripe Configuration — PASSER EN MODE LIVE POUR LA PRODUCTION
# Pour le test, garde les clés test. Pour la prod, utilise les clés live Stripe.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=__COPIER_DEPUIS_ENV_LOCAL__
STRIPE_SECRET_KEY=__COPIER_DEPUIS_ENV_LOCAL__
STRIPE_WEBHOOK_SECRET=__A_CONFIGURER_APRES_DEPLOY__

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=__COPIER_DEPUIS_ENV_LOCAL__

# Email (Resend)
RESEND_API_KEY=__COPIER_DEPUIS_ENV_LOCAL__
EMAIL_FROM=Theralib <noreply@theralib.net>

# App URL — IMPORTANT: mettre l'URL de production
NEXT_PUBLIC_APP_URL=https://theralib.net

# Cron Security
CRON_SECRET=__COPIER_DEPUIS_ENV_LOCAL__

# Firebase Admin SDK
FIREBASE_ADMIN_PROJECT_ID=__COPIER_DEPUIS_ENV_LOCAL__
FIREBASE_ADMIN_CLIENT_EMAIL=__COPIER_DEPUIS_ENV_LOCAL__
FIREBASE_ADMIN_PRIVATE_KEY=__COPIER_LA_CLE_COMPLETE_DEPUIS_ENV_LOCAL__
